# Normalise all text files to LF in the repo; Git converts on checkout for Windows
* text=auto eol=lf

# Force these binary formats to stay binary
*.png  binary
*.jpg  binary
*.jpeg binary
*.gif  binary
*.ico  binary
*.woff binary
*.woff2 binary
*.ttf  binary
*.eot  binary
*.mp4  binary
*.webm binary
