{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "experimentalServices": {
    "frontend": {
      "entrypoint": "frontend",
      "routePrefix": "/",
      "framework": "vite"
    },
    "backend": {
      "entrypoint": "backend/main.py",
      "routePrefix": "/api",
      "framework": "fastapi",
      "maxDuration": 60,
      "excludeFiles": [
        "frontend/**",
        "scripts/**",
        "**/__pycache__/**",
        "**/*.pyc",
        "**/.pytest_cache/**"
      ]
    }
  }
}
