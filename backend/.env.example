# Copy this file to .env and fill in your real values.
# NEVER commit .env — it is listed in .gitignore.

# ── OpenRouter AI ─────────────────────────────────────────────────────────────
# Get your key at https://openrouter.ai/keys
OPENROUTER_API_KEY=your_primary_openrouter_key_here

# Optional fallback key — used automatically when primary hits rate limit / timeout
OPENROUTER_API_KEY_2=your_secondary_openrouter_key_here

# Model to use (see https://openrouter.ai/models)
MODEL_ID=google/gemini-2.0-flash-001

# ── Supabase (optional) ───────────────────────────────────────────────────────
# Leave blank to use local JSON fallback storage instead
SUPABASE_URL=your_supabase_project_url_here
SUPABASE_ANON_KEY=your_supabase_anon_key_here
